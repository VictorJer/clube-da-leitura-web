<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    @*Importação do CSS do bootstrap*@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <title>@ViewBag.Titulo - Clube Da Leitura</title>
</head>

<body>
    @*Barra de navegação*@
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
        <div class="container">

            @*text-dark deixa preto/text-decor tira a linha *@
            <a class="nav-brand fw-semibold text-dark text-decor" asp-controller="Home" asp-action="Index">Clube da Leitura</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuPrincipal">
                <div class="navbar-nav ms-outo">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">Início</a>
                    <a class="nav-link" asp-controller="Caixa" asp-action="Listar">Controle de Caixas</a>
                </div>
            </div>
        </div>
    </nav>

    @*Cabeçalho da Página*@
    <header class="container py-4" style="padding: 10px 20px">
        <h2>@ViewBag.Titulo</h2>
    </header>

    @*Conteudo da pagina*@
    <main class="container pb-5">
        @RenderBody()
    </main>

    @*Importação do JS do botstrap*@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
</body>

</html>
